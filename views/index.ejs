<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Sleeper Cell Scanner</title>
  <link rel="stylesheet" href="/public/style.css" />
</head>
<body class="scanline">
  <main class="container">
    <div class="topbar">
      <div class="brand"><span class="dot"></span> sleeper bureau</div>
      <span class="badge">INTEL TERMINAL</span>
    </div>

    <div class="ticker" data-ticker>Initializing signal stream...</div>

    <section class="hero">
      <h1>Sleeper Cell Scanner</h1>
      <p>Enter any X handle to analyze their sleeper cell potential.</p>
    </section>

    <section class="layout">
      <div class="col">
        <section class="card">
          <form method="post" action="/analyze" data-scan-form>
            <div class="form-row">
              <input name="handle" placeholder="@elonmusk" value="<%= input || '' %>" />
              <button type="submit" data-scan-submit>Run Deep Scan</button>
            </div>
            <p class="subtle">Results are cached for faster repeat lookups.</p>
          </form>
        </section>

        <section class="card reveal-hidden" data-scan-loading>
          <h3 style="margin:0 0 6px;">🔍 Scanning in progress...</h3>
          <p class="subtle" style="margin:0;">Clearing previous dossier, ingesting fresh signal, compiling new readout.</p>
        </section>

        <section class="card scan-stage reveal-hidden" data-scan-stage data-chip-words='[]'>
          <div class="scan-grid">
            <div class="radar" data-radar>
              <div class="ring r1"></div>
              <div class="ring r2"></div>
              <div class="ring r3"></div>
              <div class="sweep"></div>
              <div class="blip b1"></div>
              <div class="blip b2"></div>
              <div class="blip b3"></div>
            </div>
            <div>
              <h3 style="margin:0 0 8px">Live Scan Sequence</h3>
              <div class="scan-feed" data-scan-feed></div>
              <div class="chip-row" data-chip-row></div>
            </div>
          </div>
        </section>

        <div data-results-root>
          <%- include('partials_results', { result }) %>
        </div>
      </div>

      <aside class="col">
        <section class="card">
          <h3 style="margin-top:0">Live Ops Terminal</h3>
          <div class="terminal" data-terminal></div>
        </section>

        <section class="card">
          <h3 style="margin-top:0">How It Works</h3>
          <ul class="clean">
            <li>Enter any X handle to analyze.</li>
            <li>Results are cached for faster reloads.</li>
            <li>Admin controls affect future analyses.</li>
          </ul>
        </section>
      </aside>
    </section>
  </main>
  <script src="/public/app.js"></script>
</body>
</html>
