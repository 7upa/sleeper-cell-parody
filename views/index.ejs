<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Sleeper Cell Scanner</title>
  <link rel="stylesheet" href="/public/style.css" />
</head>
<body class="scanline">
  <main class="container">
    <div class="topbar">
      <div class="brand"><span class="dot"></span> sleeper bureau</div>
      <span class="badge">PARODY INTEL TERMINAL</span>
    </div>

    <div class="ticker" data-ticker>Initializing signal stream...</div>

    <section class="hero">
      <h1>Sleeper Cell Scanner</h1>
      <p>First scan locks the profile forever. Repeat scans replay the same classified snapshot.</p>
    </section>

    <section class="layout">
      <div class="col">
        <section class="card">
          <form method="post" action="/analyze">
            <div class="form-row">
              <input name="handle" placeholder="@elonmusk" value="<%= input || '' %>" />
              <button type="submit">Run Deep Scan</button>
            </div>
            <p class="subtle">One canonical result per handle. No drift. No rewrites.</p>
          </form>
        </section>

        <% if (result && result.error) { %>
          <section class="card"><strong><%= result.error %></strong></section>
        <% } %>

        <% if (result && !result.error) { %>
          <section class="card" data-score data-score="<%= result.score %>">
            <h2 style="margin-top:0">@<%= result.handle %></h2>
            <p>
              Verdict:
              <% if (result.verdict === 'CLEAR') { %><span class="pill ok">CLEAR</span><% } %>
              <% if (result.verdict === 'WATCHLIST') { %><span class="pill watch">WATCHLIST</span><% } %>
              <% if (result.verdict === 'SLEEPER_CELL') { %><span class="pill bad">SLEEPER CELL</span><% } %>
            </p>

            <div class="kpi">
              <div class="item"><div class="label">Threat Score</div><div class="value"><%= result.score %>/100</div></div>
              <div class="item"><div class="label">Confidence</div><div class="value"><%= result.confidence %>%</div></div>
              <div class="item"><div class="label">Source</div><div class="value" style="font-size:14px;"><%= result.fromCache ? 'Replay Cache' : 'Fresh Analysis' %></div></div>
            </div>

            <div class="meter-wrap">
              <div class="meter-head"><span>Threat meter</span><span data-meter-value>0%</span></div>
              <div class="meter"><div class="meter-fill" data-meter-fill></div></div>
            </div>

            <p class="subtle" style="margin-top:10px;">First analyzed: <code><%= result.createdAt %> UTC</code> · Algorithm: <code><%= result.algorithmVersion %></code></p>
          </section>

          <section class="card">
            <h3 style="margin-top:0">Analyst reasoning</h3>
            <ul class="clean">
              <% result.reasons.forEach((r) => { %>
                <li><%= r %></li>
              <% }) %>
            </ul>
          </section>

          <section class="card">
            <h3 style="margin-top:0">Evidence snippets</h3>
            <ul class="clean">
              <% (result.evidence?.snippets || []).forEach((s) => { %>
                <li><%= s %></li>
              <% }) %>
            </ul>
          </section>
        <% } %>
      </div>

      <aside class="col">
        <section class="card">
          <h3 style="margin-top:0">Live Ops Terminal</h3>
          <div class="terminal" data-terminal></div>
        </section>

        <section class="card">
          <h3 style="margin-top:0">Protocol</h3>
          <ul class="clean">
            <li>Handle normalization strips @ and lowercases.</li>
            <li>First analysis is immutable and persisted.</li>
            <li>Subsequent lookups replay canonical result.</li>
            <li>Admin controls only affect future handles.</li>
          </ul>
        </section>
      </aside>
    </section>
  </main>
  <script src="/public/app.js"></script>
</body>
</html>
